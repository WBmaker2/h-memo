rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasValidEncodedMemoDocumentId(pathMemoId, originalMemoId) {
      return originalMemoId is string
        && originalMemoId != ""
        && pathMemoId.matches("memo~[0-9a-fA-F]{4}([0-9a-fA-F]{4})*");
    }

    function hasValidSchemaV2SnapshotShape(uid) {
      return request.resource.data.keys().hasOnly([
          "schemaVersion",
          "userId",
          "createdAt",
          "memoCount",
          "state",
          "savedAt"
        ])
        && request.resource.data.keys().hasAll([
          "schemaVersion",
          "userId",
          "createdAt",
          "memoCount",
          "state"
        ])
        && request.resource.data.schemaVersion == 2
        && request.resource.data.userId == uid
        && request.resource.data.createdAt is string
        && request.resource.data.memoCount is int
        && request.resource.data.memoCount >= 0
        && (request.resource.data.state == "writing" || request.resource.data.state == "complete")
        && (
          !request.resource.data.keys().hasAny(["savedAt"])
          || request.resource.data.savedAt is timestamp
        );
    }

    function isWritingSchemaV2Snapshot(uid) {
      return hasValidSchemaV2SnapshotShape(uid)
        && request.resource.data.state == "writing"
        && !request.resource.data.keys().hasAny(["savedAt"]);
    }

    function isCompletingSchemaV2Snapshot(uid) {
      return hasValidSchemaV2SnapshotShape(uid)
        && resource.data.schemaVersion == 2
        && resource.data.state == "writing"
        && request.resource.data.state == "complete"
        && request.resource.data.savedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["state", "savedAt"]);
    }

    function hasValidCanonicalReference(reference) {
      return reference == null || (
        reference is map
        && reference.keys().hasOnly(["snapshotId", "savedAt"])
        && reference.keys().hasAll(["snapshotId", "savedAt"])
        && reference.snapshotId is string
        && reference.savedAt is timestamp
      );
    }

    function hasValidCanonicalMemoShape(uid, memoId) {
      return request.resource.data.keys().hasOnly([
          "userId",
          "memoId",
          "active",
          "pending"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "memoId",
          "active",
          "pending"
        ])
        && request.resource.data.userId == uid
        && (
          (
            request.resource.data.memoId == memoId
            && !memoId.matches("memo~[0-9a-fA-F]{4}([0-9a-fA-F]{4})*")
          )
          || hasValidEncodedMemoDocumentId(memoId, request.resource.data.memoId)
        )
        && hasValidCanonicalReference(request.resource.data.active)
        && hasValidCanonicalReference(request.resource.data.pending);
    }

    function hasValidCanonicalMemoTransition(uid, memoId) {
      return hasValidCanonicalMemoShape(uid, memoId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["active", "pending"])
        && (
          (
            request.resource.data.pending != null
            && (
              request.resource.data.active == resource.data.active
              || request.resource.data.active == resource.data.pending
              || request.resource.data.active == null
            )
          )
          || (
            request.resource.data.pending == null
            && (
              request.resource.data.active == resource.data.active
              || (
                resource.data.pending != null
                && request.resource.data.active == resource.data.pending
              )
            )
          )
        );
    }

    function hasValidSnapshotMemoShape(uid, memoId) {
      return request.resource.data.keys().hasOnly([
          "userId",
          "memoId",
          "memo"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "memoId",
          "memo"
        ])
        && request.resource.data.userId == uid
        && (
          (
            request.resource.data.memoId == memoId
            && !memoId.matches("memo~[0-9a-fA-F]{4}([0-9a-fA-F]{4})*")
          )
          || hasValidEncodedMemoDocumentId(memoId, request.resource.data.memoId)
        )
        && request.resource.data.memo is map
        && request.resource.data.memo.id == request.resource.data.memoId;
    }

    function hasValidServerMemoDeleteShape(uid, memoId) {
      return request.resource.data.keys().hasOnly([
          "userId",
          "memoId",
          "snapshotId",
          "deletedAt"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "memoId",
          "snapshotId",
          "deletedAt"
        ])
        && request.resource.data.userId == uid
        && (
          (
            request.resource.data.memoId == memoId
            && !memoId.matches("memo~[0-9a-fA-F]{4}([0-9a-fA-F]{4})*")
          )
          || hasValidEncodedMemoDocumentId(memoId, request.resource.data.memoId)
        )
        && request.resource.data.snapshotId is string
        && request.resource.data.deletedAt is timestamp;
    }

    function hasValidBackupStateShape(uid) {
      return request.resource.data.keys().hasOnly([
          "userId",
          "activeSnapshotId",
          "pendingSnapshotId",
          "activatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "userId",
          "activeSnapshotId",
          "pendingSnapshotId",
          "activatedAt"
        ])
        && request.resource.data.userId == uid
        && (
          request.resource.data.activeSnapshotId == null
          || request.resource.data.activeSnapshotId is string
        )
        && (
          request.resource.data.pendingSnapshotId == null
          || request.resource.data.pendingSnapshotId is string
        )
        && (
          request.resource.data.activatedAt == null
          || request.resource.data.activatedAt is timestamp
        );
    }

    function hasValidInitialBackupLease(uid) {
      return hasValidBackupStateShape(uid)
        && request.resource.data.activeSnapshotId == null
        && request.resource.data.pendingSnapshotId is string
        && request.resource.data.activatedAt == null;
    }

    function hasValidPendingBackupLease(uid) {
      return hasValidBackupStateShape(uid)
        && request.resource.data.pendingSnapshotId is string
        && request.resource.data.activeSnapshotId == resource.data.activeSnapshotId
        && request.resource.data.activatedAt == resource.data.activatedAt;
    }

    function hasValidBackupActivationShape(uid) {
      return hasValidBackupStateShape(uid)
        && resource.data.pendingSnapshotId is string
        && request.resource.data.activeSnapshotId == resource.data.pendingSnapshotId
        && request.resource.data.pendingSnapshotId == null
        && request.resource.data.activatedAt is timestamp
        && getAfter(/databases/$(database)/documents/users/$(uid)/backupSnapshots/$(request.resource.data.activeSnapshotId)).data.schemaVersion == 2
        && getAfter(/databases/$(database)/documents/users/$(uid)/backupSnapshots/$(request.resource.data.activeSnapshotId)).data.userId == uid
        && getAfter(/databases/$(database)/documents/users/$(uid)/backupSnapshots/$(request.resource.data.activeSnapshotId)).data.state == "complete";
    }

    match /users/{uid}/memos/{memoId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasValidCanonicalMemoShape(uid, memoId);
      allow update: if isOwner(uid) && hasValidCanonicalMemoTransition(uid, memoId);
      allow delete: if false;
    }

    match /users/{uid}/backupSnapshots/{snapshotId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isWritingSchemaV2Snapshot(uid);
      allow update: if isOwner(uid) && isCompletingSchemaV2Snapshot(uid);
      allow delete: if false;
    }

    match /users/{uid}/backupSnapshots/{snapshotId}/memos/{memoId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasValidSnapshotMemoShape(uid, memoId);
      allow update, delete: if false;
    }

    match /users/{uid}/backupState/current {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasValidInitialBackupLease(uid);
      allow update: if isOwner(uid) && (
        hasValidPendingBackupLease(uid)
        || hasValidBackupActivationShape(uid)
      );
      allow delete: if false;
    }

    match /users/{uid}/serverMemoDeletes/{memoId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && hasValidServerMemoDeleteShape(uid, memoId);
      allow delete: if isOwner(uid);
    }
  }
}
